# OPENROUTER_API_KEY: Required for OpenRouter AI Gateway calls.
# Set this to your OpenRouter API key. Do NOT commit real keys to the repo.
OPENROUTER_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google OAuth 2.0 Credentials (Auto-configured with the official credentials)
GOOGLE_CLIENT_ID="PLACEHOLDER_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="PLACEHOLDER_GOOGLE_CLIENT_SECRET"

# Supabase public client configuration
# Use only the anon/public key here; do not store service_role keys in client-side code.
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-public-anon-key"

